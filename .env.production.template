# =============================================================
# AskIEP Production Environment Template
# =============================================================
# Copy this to .env.production and fill in your values.
# These values should also be configured as GitHub Actions secrets
# in your repository Settings > Environments > production.
# =============================================================

# --- GCP ---
GCP_PROJECT_ID=askiep-production
GCP_REGION=us-central1
GCP_ARTIFACT_REPOSITORY=iep-apps
GCP_SA_NAME=iep-ci-deployer-prod

# --- Application ---
APP_ENVIRONMENT=production
API_SERVER_PORT=8080

# --- JWT ---
JWT_SECRET=
JWT_EXPIRATION_TIME_IN_MINUTES=60

# --- Database (Cloud SQL) ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL_MODE=verify-ca
CLOUDSQL_CONNECTION_NAME=askiep-production:us-central1:iepdatabaseprod

# --- reCAPTCHA ---
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# --- Email (Azure/Microsoft Graph) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
FROM_EMAIL_ADDRESS=
NOTIFY_EMAILS=

# --- Telegram (Admin Notifications) ---
TELEGRAM_API_KEY=
TELEGRAM_CHAT_ID=

# --- Google Cloud Storage ---
GCS_BUCKET=iep-documents-prod
GCS_CONFIG_BUCKET=iep-config-prod
ENABLE_S3=true
LOCAL_BASE_FOLDER=/tmp/iep-uploads
CONFIG_SOURCE_FOLDER=/tmp/iep-config

# --- AI / Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
AI_MODEL=gemini-flash-latest
AI_TEMPERATURE=0.3

# --- Encryption ---
CONFIG_ENCRYPTION_KEY=

# --- Firebase (Web UI build args) ---
VITE_BASE_API_URL=https://api.askiep.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Stripe ---
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_RECAPTCHA_SITE_KEY=

# --- Service Account Key (for GH Actions, base64-encoded JSON) ---
# GCP_SA_KEY=<contents of service account JSON key>
