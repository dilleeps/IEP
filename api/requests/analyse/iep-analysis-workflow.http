### ===========================================
### DASHBOARD & ANALYTICS
### ===========================================

### Step 15: Get Dashboard Overview
GET {{BASE_URL}}/api/v1/dashboard/overview?childId={{CHILD_ID}}
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Dashboard overview retrieved", function () {
        client.assert(response.status === 200, "Expected 200");
        const data = response.body.data;
        client.log("✓ Dashboard Overview:");
        
        if (data.child) {
            client.log("  Child: " + data.child.name);
        }
        
        if (data.complianceHealth) {
            client.log("  Service Delivery: " + data.complianceHealth.serviceDeliveryPercentage + "%");
            client.log("  Missed Sessions: " + data.complianceHealth.totalMissedSessions);
            client.log("  Review Status: " + data.complianceHealth.reviewStatus);
        }
        
        if (data.goalMastery) {
            client.log("  Mastered Goals: " + data.goalMastery.masteredGoals);
            client.log("  Progressing Goals: " + data.goalMastery.progressingGoals);
            client.log("  Emerging Goals: " + data.goalMastery.emergingGoals);
            client.log("  Average Progress: " + data.goalMastery.averageProgress + "%");
        }
        
        if (data.actionItems && data.actionItems.length > 0) {
            client.log("  Action Items: " + data.actionItems.length);
            data.actionItems.forEach((item, i) => {
                client.log("    " + (i+1) + ". [" + item.priority + "] " + item.title);
            });
        }
    });
%}

