### ===========================================
### IEP Document Analysis - Complete Workflow
### Parent: parent@askiep.com
### ===========================================

### Step 1: Parent Login
POST {{BASE_URL}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{PARENT_EMAIL}}",
  "password": "{{DEFAULT_PASSWORD}}"
}

> {%
    client.test("Parent login successful", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        const body = response.body;
        client.assert(!!body.token, "Token missing in response");
        client.global.set("PARENT_TOKEN", body.token);
        client.log("✓ Parent authenticated - Token saved");
    });
%}



### Step 3: Create/Get Child Profile
POST {{BASE_URL}}/api/v1/children
Authorization: Bearer {{PARENT_TOKEN}}
Content-Type: application/json

{
  "name": "{{PARENT_CHILD_1_NAME}}",
  "dateOfBirth": "2016-01-15",
  "grade": "{{PARENT_CHILD_1_GRADE}}",
  "disabilities": ["ADHD", "Specific Learning Disability"]
}

> {%
    client.test("Child profile created", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        const childId = response.body.id;
        client.assert(!!childId, "Child ID missing");
        client.global.set("CHILD_ID", childId);
        client.log("✓ Child profile created - ID: " + childId);
    });
%}

### Step 4: List Children (Verify Child Exists)
GET {{BASE_URL}}/api/v1/children?limit=50&offset=0
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Child listed successfully", function () {
        client.assert(response.status === 200, "Expected 200");
        const children = response.body.children || [];
        const childId = client.global.get("CHILD_ID");
        const found = children.some(c => c.id === childId);
        client.assert(found, "Created child not found in list");
        client.log("✓ Child found in list");
    });
%}

### ===========================================
### DOCUMENT 1: Current Year IEP (Reading Goals)
### ===========================================

### Step 4.1: Delete All Documents for Child (Testing Cleanup)
# Use this to clean up test data before starting a new workflow
DELETE {{BASE_URL}}/api/v1/iep/child/{{CHILD_ID}}/all
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("All documents deleted", function () {
        client.assert(response.status === 200, "Expected 200");
        const deletedCount = response.body.data.deletedCount;
        client.log("✓ Deleted " + deletedCount + " documents for child");
    });
%}

### Step 5.1: Upload IEP Document #1 - Current Year Reading Goals
POST {{BASE_URL}}/api/v1/iep/upload
Authorization: Bearer {{PARENT_TOKEN}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="childId"

{{CHILD_ID}}
--boundary
Content-Disposition: form-data; name="file"; filename="doc1.pdf"
Content-Type: application/pdf

< ./docs/doc1.pdf
--boundary--

> {%
    client.test("Document 1 uploaded successfully", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        const docId = response.body.data.documentId;
        client.assert(!!docId, "Document ID missing");
        client.global.set("DOC_1_ID", docId);
        client.log("✓ Document 1 uploaded - ID: " + docId);
        client.log("  Status: " + response.body.data.status);
        client.log("  Analysis Status: " + response.body.data.analysisStatus);
    });
%}

### Step 5.2: Get Document #1 Details
GET {{BASE_URL}}/api/v1/iep/{{DOC_1_ID}}
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Document 1 details retrieved", function () {
        client.assert(response.status === 200, "Expected 200");
        client.log("✓ Document 1 details:");
        client.log("  File: " + response.body.originalFileName);
        client.log("  Status: " + response.body.status);
        client.log("  Analysis: " + response.body.analysisStatus);
    });
%}

### Step 5.2.1: Delete Document #1 (If Duplicate or Need to Re-upload)
DELETE {{BASE_URL}}/api/v1/iep/{{DOC_1_ID}}
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Document 1 deleted successfully", function () {
        client.assert(response.status === 204, "Expected 204 No Content");
        client.log("✓ Document 1 deleted - can now re-upload");
        client.log("  Use Step 5.1 to upload again if needed");
    });
%}

### Step 5.3: Analyze Document #1 with AI (NDJSON Stream)
# NOTE: This returns NDJSON stream (application/x-ndjson)
# Watch the response for progress events (30-60 seconds)
# Format: One JSON object per line
# Event types: {type:"log"}, {type:"result"}, {type:"error"}
GET {{BASE_URL}}/api/v1/iep/{{DOC_1_ID}}/analyze-iep
Authorization: Bearer {{PARENT_TOKEN}}
Accept: application/x-ndjson

> {%
    client.test("Document 1 analysis triggered", function () {
        client.assert(response.status === 200, "Expected 200");
        client.log("✓ AI Analysis started for Document 1");
        client.log("  Watch for NDJSON progress events...");
        client.log("  Content-Type: " + response.headers.valueOf("Content-Type"));
    });
%}

### Step 5.4: Wait 60 seconds for analysis to complete
# In real usage, you'd listen to SSE events
# For testing, we wait and then check status

### Step 5.5: Get Extraction Results for Review (Document #1)
GET {{BASE_URL}}/api/v1/iep/{{DOC_1_ID}}/extraction
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Document 1 extraction retrieved", function () {
        client.assert(response.status === 200, "Expected 200");
        const data = response.body.data;
        client.log("✓ Extraction results for Document 1:");
        client.log("  Status: " + data.extractionStatus);
        client.log("  Review Required: " + data.reviewRequired);
        if (data.lowConfidenceFields && data.lowConfidenceFields.length > 0) {
            client.log("  Low Confidence Fields: " + data.lowConfidenceFields.join(", "));
        }
        if (data.extractedData) {
            const metadata = data.extractedData.metadata || {};
            client.log("  Student: " + (metadata.studentName || "N/A"));
            client.log("  IEP Dates: " + (metadata.iepStartDate || "N/A") + " to " + (metadata.iepEndDate || "N/A"));
            const goals = data.extractedData.goals || [];
            client.log("  Goals Extracted: " + goals.length);
            const services = data.extractedData.services || [];
            client.log("  Services Extracted: " + services.length);
        }
    });
%}

### Step 5.6: Submit Corrections for Document #1 (if needed)
POST {{BASE_URL}}/api/v1/iep/{{DOC_1_ID}}/corrections
Authorization: Bearer {{PARENT_TOKEN}}
Content-Type: application/json

{
  "corrections": [
    {
      "field": "metadata.iepEndDate",
      "originalValue": "2026-09-20",
      "correctedValue": "2026-09-19",
      "aiConfidence": 0.85,
      "reason": "End date should be one day before start date anniversary"
    }
  ],
  "reviewCompleted": true
}

> {%
    client.test("Document 1 corrections submitted", function () {
        client.assert(response.status === 200, "Expected 200");
        client.log("✓ Corrections applied to Document 1");
        client.log("  Extraction marked as reviewed");
    });
%}

### Step 5.7: Check if Document #1 Can Be Finalized
GET {{BASE_URL}}/api/v1/iep/{{DOC_1_ID}}/can-finalize
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Document 1 finalization check", function () {
        client.assert(response.status === 200, "Expected 200");
        const canFinalize = response.body.data.canFinalize;
        client.log("✓ Can finalize Document 1: " + canFinalize);
        if (!canFinalize && response.body.data.reason) {
            client.log("  Reason: " + response.body.data.reason);
        }
    });
%}

### Step 5.8: Finalize Document #1 (Normalize to Database)
POST {{BASE_URL}}/api/v1/iep/{{DOC_1_ID}}/finalize
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Document 1 finalized", function () {
        client.assert(response.status === 200, "Expected 200");
        const data = response.body.data;
        client.log("✓ Document 1 finalized successfully");
        client.log("  Goals Created: " + (data.goalsCreated || 0));
        client.log("  Services Created: " + (data.servicesCreated || 0));
        client.log("  Smart Prompts Created: " + (data.promptsCreated || 0));
        
        // EXTRACT GOAL AND SERVICE IDs FOR LATER USE
        // These IDs are auto-generated during finalization
        // You'll need to query them to use in progress/service logging
        if (data.goals && data.goals.length > 0) {
            client.global.set("GOAL_ID", data.goals[0].id);
            client.log("  First Goal ID saved: " + data.goals[0].id);
        }
        if (data.services && data.services.length > 0) {
            client.global.set("SERVICE_ID", data.services[0].id);
            client.log("  First Service ID saved: " + data.services[0].id);
        }
    });
%}

### Step 5.9: Get Goals for Child (Auto-Generated from Finalization)
# Goal IDs are created during document finalization
# Use this to see all goals and their IDs
GET {{BASE_URL}}/api/v1/goal-progress/child/{{CHILD_ID}}
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Goals retrieved", function () {
        if (response.status === 200) {
            const goals = response.body.data || [];
            client.log("✓ Total goals for child: " + goals.length);
            goals.forEach((goal, i) => {
                client.log("  " + (i+1) + ". " + goal.goalName + " (ID: " + goal.id + ")");
                // Save first goal ID for testing
                if (i === 0) {
                    client.global.set("GOAL_ID", goal.id);
                    client.log("     → Saved as GOAL_ID");
                }
            });
        }
    });
%}

### Step 5.10: Get Services for Child (Auto-Generated from Finalization)
# Service IDs are created during document finalization
# Use this to see all services and their IDs
GET {{BASE_URL}}/api/v1/services/child/{{CHILD_ID}}
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Services retrieved", function () {
        if (response.status === 200) {
            const services = response.body.data || [];
            client.log("✓ Total services for child: " + services.length);
            services.forEach((service, i) => {
                client.log("  " + (i+1) + ". " + service.serviceType + " - " + service.minutesPerSession + " min/session (ID: " + service.id + ")");
                // Save first service ID for testing
                if (i === 0) {
                    client.global.set("SERVICE_ID", service.id);
                    client.log("     → Saved as SERVICE_ID");
                }
            });
        }
    });
%}

