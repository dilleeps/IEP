Authorization: Bearer {{PARENT_TOKEN}}
Content-Type: application/json

{
  "goalId": "{{GOAL_ID}}",
  "childId": "{{CHILD_ID}}",
  "reportedDate": "2025-11-15",
  "currentLevel": "Alex read 70 words per minute on a 4th grade passage with 88% accuracy",
  "progressValue": 70,
  "progressUnit": "words per minute",
  "notes": "Significant improvement in fluency. Alex is gaining confidence and no longer avoiding reading activities.",
