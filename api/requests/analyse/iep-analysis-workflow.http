### Step 9.2: Analyze Document #5 (Should detect multiple red flags)
GET {{BASE_URL}}/api/v1/iep/{{DOC_5_ID}}/analyze-iep
Authorization: Bearer {{PARENT_TOKEN}}
Accept: application/x-ndjson

> {%
    client.test("Document 5 analysis triggered", function () {
        client.assert(response.status === 200, "Expected 200");
        client.log("✓ AI Analysis started for Document 5 (Red Flags)");
        client.log("  This document should trigger multiple Smart Prompts");
    });
%}

### Step 9.3: Get Extraction - Should Show Red Flags
GET {{BASE_URL}}/api/v1/iep/{{DOC_5_ID}}/extraction
Authorization: Bearer {{PARENT_TOKEN}}

> {%
    client.test("Document 5 extraction shows red flags", function () {
        client.assert(response.status === 200, "Expected 200");
        const data = response.body.data;
        client.log("✓ Document 5 extraction results:");
        if (data.extractedData && data.extractedData.redFlags) {
            const redFlags = data.extractedData.redFlags;
            client.log("  Red Flags Detected: " + redFlags.length);
            redFlags.forEach((flag, i) => {
                client.log("  " + (i+1) + ". [" + flag.severity + "] " + flag.type + ": " + flag.message.substring(0, 80));
            });
        }
    });
%}

