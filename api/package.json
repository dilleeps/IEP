{
  "name": "askiep-api",
  "version": "0.1.0",
  "description": "",
  "license": "ISC",
  "author": "Muthukumaran Navaneethakrishnan",
  "type": "module",
  "main": "index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc",
    "db:migrate": "tsx --env-file=../../.env src/db/cli.ts up",
    "db:migrate:down": "tsx --env-file=../../.env src/db/cli.ts down",
    "db:migrate:status": "tsx --env-file=../../.env src/db/cli.ts status",
    "db:seed": "tsx --env-file=../../.env src/db/seed-cli.ts up",
    "db:seed:down": "tsx --env-file=../../.env src/db/seed-cli.ts down",
    "db:seed:status": "tsx --env-file=../../.env src/db/seed-cli.ts status",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "echo '\n🚀  API docs at http://localhost:3000/api-docs\n'"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.18.0",
    "@google/genai": "^1.34.0",
    "@langchain/core": "^1.1.11",
    "@langchain/google-genai": "^2.1.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.3",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "express-winston": "^4.2.0",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.6",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "stripe": "^20.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.2",
    "winston": "^3.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "testcontainers": "^11.11.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
